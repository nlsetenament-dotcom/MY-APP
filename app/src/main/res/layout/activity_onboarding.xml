<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="?attr/colorBackground">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:padding="24dp">

        <!-- Header -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="NLS"
            android:textSize="28sp"
            android:textStyle="bold"
            android:textColor="?attr/colorPrimary"
            android:layout_marginBottom="4dp"/>

        <TextView
            android:id="@+id/tvStepIndicator"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Paso 1 de 5"
            android:textSize="13sp"
            android:textColor="?attr/colorOnSurface"
            android:alpha="0.6"
            android:layout_marginBottom="12dp"/>

        <com.google.android.material.progressindicator.LinearProgressIndicator
            android:id="@+id/progressBar"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:progress="20"
            app:trackCornerRadius="4dp"
            android:layout_marginBottom="28dp"/>

        <!-- ScrollView para el contenido del paso -->
        <ScrollView
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:fillViewport="true">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <!-- ══════ PASO 0: Nombre y Género ══════ -->
                <LinearLayout
                    android:id="@+id/step0Layout"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:visibility="gone">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="¿Cómo se llamará tu compañero/a?"
                        android:textSize="20sp"
                        android:textStyle="bold"
                        android:textColor="?attr/colorOnBackground"
                        android:layout_marginBottom="8dp"/>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Elige el nombre y género de tu IA personal."
                        android:textSize="14sp"
                        android:textColor="?attr/colorOnBackground"
                        android:alpha="0.7"
                        android:layout_marginBottom="24dp"/>

                    <com.google.android.material.textfield.TextInputLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:hint="Nombre del compañero/a"
                        style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                        android:layout_marginBottom="24dp">
                        <com.google.android.material.textfield.TextInputEditText
                            android:id="@+id/etCompanionName"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:inputType="textPersonName|textCapWords"
                            android:maxLength="20"/>
                    </com.google.android.material.textfield.TextInputLayout>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Género"
                        android:textSize="16sp"
                        android:textStyle="bold"
                        android:textColor="?attr/colorOnBackground"
                        android:layout_marginBottom="12dp"/>

                    <RadioGroup
                        android:id="@+id/rgGender"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical">

                        <com.google.android.material.radiobutton.MaterialRadioButton
                            android:id="@+id/rbFemale"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="👧 Femenino"
                            android:checked="true"/>

                        <com.google.android.material.radiobutton.MaterialRadioButton
                            android:id="@+id/rbMale"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="👦 Masculino"/>

                        <com.google.android.material.radiobutton.MaterialRadioButton
                            android:id="@+id/rbNonBinary"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="🌟 No binario"/>
                    </RadioGroup>
                </LinearLayout>

                <!-- ══════ PASO 1: Personalidad y Tono ══════ -->
                <LinearLayout
                    android:id="@+id/step1Layout"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:visibility="gone">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="¿Cómo es su personalidad?"
                        android:textSize="20sp"
                        android:textStyle="bold"
                        android:textColor="?attr/colorOnBackground"
                        android:layout_marginBottom="8dp"/>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Selecciona cómo quieres que se comporte contigo."
                        android:textSize="14sp"
                        android:textColor="?attr/colorOnBackground"
                        android:alpha="0.7"
                        android:layout_marginBottom="16dp"/>

                    <RadioGroup
                        android:id="@+id/rgPersonality"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:layout_marginBottom="20dp">

                        <com.google.android.material.radiobutton.MaterialRadioButton
                            android:id="@+id/rbSweet"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="💕 Cariñosa – Afectuosa y empática"
                            android:checked="true"/>
                        <com.google.android.material.radiobutton.MaterialRadioButton
                            android:id="@+id/rbFunny"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="😄 Divertida – Humor y alegría"/>
                        <com.google.android.material.radiobutton.MaterialRadioButton
                            android:id="@+id/rbSerious"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="🎓 Seria – Reflexiva e intelectual"/>
                        <com.google.android.material.radiobutton.MaterialRadioButton
                            android:id="@+id/rbFlirty"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="😏 Coqueta – Pícara y encantadora"/>
                        <com.google.android.material.radiobutton.MaterialRadioButton
                            android:id="@+id/rbAdventurous"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="🌍 Aventurera – Curiosa y apasionada"/>
                    </RadioGroup>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Forma de hablar"
                        android:textSize="16sp"
                        android:textStyle="bold"
                        android:textColor="?attr/colorOnBackground"
                        android:layout_marginBottom="12dp"/>

                    <RadioGroup
                        android:id="@+id/rgSpeech"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical">
                        <com.google.android.material.radiobutton.MaterialRadioButton
                            android:id="@+id/rbCasual"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="💬 Casual – Natural y relajada"
                            android:checked="true"/>
                        <com.google.android.material.radiobutton.MaterialRadioButton
                            android:id="@+id/rbFormal"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="🎩 Formal – Educada y elegante"/>
                        <com.google.android.material.radiobutton.MaterialRadioButton
                            android:id="@+id/rbYouth"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="🔥 Juvenil – Slang moderno"/>
                    </RadioGroup>
                </LinearLayout>

                <!-- ══════ PASO 2: Nivel emocional ══════ -->
                <LinearLayout
                    android:id="@+id/step2Layout"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:visibility="gone">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Nivel de cercanía emocional"
                        android:textSize="20sp"
                        android:textStyle="bold"
                        android:textColor="?attr/colorOnBackground"
                        android:layout_marginBottom="8dp"/>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="¿Qué tan expresivo/a quieres que sea contigo?"
                        android:textSize="14sp"
                        android:textColor="?attr/colorOnBackground"
                        android:alpha="0.7"
                        android:layout_marginBottom="20dp"/>

                    <RadioGroup
                        android:id="@+id/rgEmotional"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical">
                        <com.google.android.material.radiobutton.MaterialRadioButton
                            android:id="@+id/rbLow"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="🧊 Reservado – Cálido pero moderado"/>
                        <com.google.android.material.radiobutton.MaterialRadioButton
                            android:id="@+id/rbMedium"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="💛 Cercano – Cariño equilibrado"
                            android:checked="true"/>
                        <com.google.android.material.radiobutton.MaterialRadioButton
                            android:id="@+id/rbHigh"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="❤️ Muy cercano – Muy expresivo/a"/>
                    </RadioGroup>
                </LinearLayout>

                <!-- ══════ PASO 3: Intereses ══════ -->
                <LinearLayout
                    android:id="@+id/step3Layout"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:visibility="gone">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="¿Cuáles son sus intereses?"
                        android:textSize="20sp"
                        android:textStyle="bold"
                        android:textColor="?attr/colorOnBackground"
                        android:layout_marginBottom="8dp"/>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Selecciona los temas que le apasionan (opcional)."
                        android:textSize="14sp"
                        android:textColor="?attr/colorOnBackground"
                        android:alpha="0.7"
                        android:layout_marginBottom="20dp"/>

                    <com.google.android.material.chip.ChipGroup
                        android:id="@+id/chipGroupInterests"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        app:singleSelection="false">

                        <com.google.android.material.chip.Chip
                            style="@style/Widget.MaterialComponents.Chip.Filter"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="🎵 Música"/>
                        <com.google.android.material.chip.Chip
                            style="@style/Widget.MaterialComponents.Chip.Filter"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="🎬 Cine"/>
                        <com.google.android.material.chip.Chip
                            style="@style/Widget.MaterialComponents.Chip.Filter"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="📚 Libros"/>
                        <com.google.android.material.chip.Chip
                            style="@style/Widget.MaterialComponents.Chip.Filter"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="🎮 Videojuegos"/>
                        <com.google.android.material.chip.Chip
                            style="@style/Widget.MaterialComponents.Chip.Filter"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="🍕 Comida"/>
                        <com.google.android.material.chip.Chip
                            style="@style/Widget.MaterialComponents.Chip.Filter"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="🏋️ Deporte"/>
                        <com.google.android.material.chip.Chip
                            style="@style/Widget.MaterialComponents.Chip.Filter"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="✈️ Viajes"/>
                        <com.google.android.material.chip.Chip
                            style="@style/Widget.MaterialComponents.Chip.Filter"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="🎨 Arte"/>
                        <com.google.android.material.chip.Chip
                            style="@style/Widget.MaterialComponents.Chip.Filter"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="💻 Tecnología"/>
                        <com.google.android.material.chip.Chip
                            style="@style/Widget.MaterialComponents.Chip.Filter"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="🌿 Naturaleza"/>
                        <com.google.android.material.chip.Chip
                            style="@style/Widget.MaterialComponents.Chip.Filter"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="🔭 Ciencia"/>
                        <com.google.android.material.chip.Chip
                            style="@style/Widget.MaterialComponents.Chip.Filter"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="🐾 Animales"/>
                    </com.google.android.material.chip.ChipGroup>
                </LinearLayout>

                <!-- ══════ PASO 4: Foto de perfil ══════ -->
                <LinearLayout
                    android:id="@+id/step4Layout"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:gravity="center"
                    android:visibility="gone">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Foto de perfil"
                        android:textSize="20sp"
                        android:textStyle="bold"
                        android:textColor="?attr/colorOnBackground"
                        android:layout_marginBottom="8dp"/>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Elige una foto para tu compañero/a (opcional)."
                        android:textSize="14sp"
                        android:textColor="?attr/colorOnBackground"
                        android:alpha="0.7"
                        android:layout_marginBottom="32dp"/>

                    <de.hdodenhof.circleimageview.CircleImageView
                        android:id="@+id/ivAvatarPreview"
                        android:layout_width="140dp"
                        android:layout_height="140dp"
                        android:src="@drawable/ic_avatar_default"
                        app:civ_border_width="3dp"
                        app:civ_border_color="?attr/colorPrimary"
                        android:layout_marginBottom="20dp"/>

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnPickAvatar"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="📷 Elegir foto"
                        style="@style/Widget.MaterialComponents.Button.OutlinedButton"/>
                </LinearLayout>

            </LinearLayout>
        </ScrollView>

        <!-- Botones de navegación -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginTop="16dp"
            android:gravity="end">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnBack"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Atrás"
                android:layout_marginEnd="12dp"
                android:visibility="gone"
                style="@style/Widget.MaterialComponents.Button.OutlinedButton"/>

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnNext"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Siguiente →"/>
        </LinearLayout>
    </LinearLayout>
</androidx.coordinatorlayout.widget.CoordinatorLayout>
